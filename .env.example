# Copy to .env for local dev. Set the same keys in Railway service variables.
# NEVER commit the real .env.

# --- Server ---
PORT=8080                      # Railway provides this automatically in prod

# --- Postgres (Railway provides DATABASE_URL automatically) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Railway bucket (S3-compatible) ---
BUCKET_ENDPOINT=https://<your-railway-bucket-endpoint>
BUCKET_REGION=auto
BUCKET_NAME=something-sweet
BUCKET_ACCESS_KEY_ID=xxxx
BUCKET_SECRET_ACCESS_KEY=xxxx
# Optional: only if the bucket is public-read. Images are proxied through the
# server by default, so leave blank for a private bucket.
BUCKET_PUBLIC_BASE=

# --- Brevo (transactional email) ---
BREVO_API_KEY=xkeysib-xxxx
BREVO_SENDER_EMAIL=somethingsweetbyerica@gmail.com
BREVO_SENDER_NAME=Something Sweet by Erica

# --- Stripe (ROTATE the keys from the old export before go-live) ---
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
