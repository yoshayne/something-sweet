# Copy to .env for local dev. Set the same keys in Railway service variables.
# NEVER commit the real .env.

# --- Server ---
PORT=8080                      # Railway provides this automatically in prod

# --- Postgres (Railway provides DATABASE_URL automatically) ---
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Optional SSL override: require | no-verify (force SSL) | disable (force off).
# Leave unset — the app auto-detects: internal *.railway.internal = no SSL,
# external *.rlwy.net proxy = SSL.
# PGSSLMODE=

# --- Railway bucket (S3-compatible) ---
# These are the names Railway's bucket plugin provides. The shorter aliases
# (BUCKET_ENDPOINT / BUCKET_REGION) are also accepted for local dev.
BUCKET_ENDPOINT_URL=https://<your-railway-bucket-endpoint>
BUCKET_DEFAULT_REGION=auto
BUCKET_NAME=something-sweet
BUCKET_ACCESS_KEY_ID=xxxx
BUCKET_SECRET_ACCESS_KEY=xxxx

# --- Brevo (transactional email) ---
# Sender must be a VERIFIED sender/domain in Brevo (SPF/DKIM) or mail lands in spam.
BREVO_API_KEY=xkeysib-xxxx
BREVO_SENDER_EMAIL=erica@somethingsweet.shop
BREVO_SENDER_NAME=Something Sweet by Erica

# Owner notification inbox + Reply-To on customer emails (defaults to
# erica@somethingsweet.shop). ADMIN_SMS is the carrier email-to-SMS gateway.
ADMIN_EMAIL=erica@somethingsweet.shop
# ADMIN_SMS=8037183346@vtext.com

# --- Stripe (ROTATE the keys from the old export before go-live) ---
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx
